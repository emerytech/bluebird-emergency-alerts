<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for APNs token registration. Use "development" for Debug builds. -->
  <!-- For TestFlight/App Store builds, Xcode typically signs with production automatically. -->
  <key>aps-environment</key>
  <string>development</string>
</dict>
</plist>
