# Copy this file to ".env" and fill in real values.
# Never commit your real .env or your APNs .p8 key.

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Optional: shell command the admin dashboard uses to restart the service.
# Example for systemd: SERVER_RESTART_COMMAND=systemctl restart bluebird
SERVER_RESTART_COMMAND=

# Optional shared-secret API key. If set, clients must include `X-API-Key: <value>` for non-health endpoints.
# Generate a long random string for production.
API_KEY=

# SQLite (used for alert logging)
DB_PATH=./data/bluebird.db

# APNs (Apple Push Notification service)
# Set true for development builds + sandbox device tokens.
APNS_USE_SANDBOX=true

# Your Apple Developer account Team ID (10 characters)
APNS_TEAM_ID=YOUR_TEAM_ID

# Key ID from Certificates, Identifiers & Profiles > Keys
APNS_KEY_ID=YOUR_KEY_ID

# Path to your Auth Key .p8 file on disk (relative or absolute)
APNS_P8_PATH=./secrets/AuthKey_XXXXXXXXXX.p8

# Your app's bundle identifier (aka APNs "topic"), e.g. com.yourschool.bluebird
APNS_BUNDLE_ID=com.example.bluebirdalerts

# Optional tuning
APNS_TIMEOUT_SECONDS=10
APNS_CONCURRENCY=50
APNS_MAX_RETRIES=2

# SMS (Twilio)
# Set true to send SMS redundantly with push notifications.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TIMEOUT_SECONDS=5
TWILIO_CONCURRENCY=20
