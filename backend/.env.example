# Copy this file to ".env" and fill in real values.
# Never commit your real .env or your APNs .p8 key.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=production

# Canonical public HTTPS URL (used in generated links, QR codes, onboarding emails)
BACKEND_PUBLIC_URL=https://bluebird-alerts.com

# Optional: shell commands the admin dashboard uses to restart the service.
SERVER_RESTART_COMMAND=
SERVER_GIT_PULL_COMMAND=

# ── Security ──────────────────────────────────────────────────────────────────
# Shared API key required on write endpoints. Generate with: openssl rand -hex 32
API_KEY=
# Session signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/bluebird.db
PLATFORM_DB_PATH=./data/platform.db

# ── Domain / Tenant ───────────────────────────────────────────────────────────
BASE_DOMAIN=bluebird-alerts.com
DEFAULT_SCHOOL_SLUG=nen
DEFAULT_SCHOOL_NAME=Northeast Nodaway RV School District

# ── Superadmin ────────────────────────────────────────────────────────────────
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=

# ── APNs (Apple Push Notifications) ──────────────────────────────────────────
# Set true for development builds + sandbox device tokens.
APNS_USE_SANDBOX=false
# Your Apple Developer account Team ID (10 characters)
APNS_TEAM_ID=YOUR_TEAM_ID
# Key ID from Certificates, Identifiers & Profiles > Keys
APNS_KEY_ID=YOUR_KEY_ID
# Path to the .p8 file on disk (relative or absolute)
APNS_P8_PATH=./secrets/AuthKey_XXXXXXXXXX.p8
# Your app's bundle identifier, e.g. com.yourschool.bluebird
APNS_BUNDLE_ID=com.example.bluebirdalerts
# Reliability tuning
APNS_TIMEOUT_SECONDS=10
APNS_CONCURRENCY=50
APNS_MAX_RETRIES=2

# ── Firebase Cloud Messaging (Android) ───────────────────────────────────────
# Server-side service account JSON (not google-services.json).
FCM_SERVICE_ACCOUNT_JSON=./secrets/firebase-service-account.json

# ── SMS / Twilio ──────────────────────────────────────────────────────────────
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TIMEOUT_SECONDS=5
TWILIO_CONCURRENCY=20

# ── SMTP (admin emails / health alerts) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
# Comma-separated list of platform admin email addresses
PLATFORM_ADMIN_EMAILS=

# ── Cloudflare DNS automation ─────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DNS_BASE_HOSTNAME=bluebird-alerts.com
CLOUDFLARE_TUNNEL_CNAME_TARGET=
CLOUDFLARE_DNS_PROXIED=true

# ── Redis / Celery ────────────────────────────────────────────────────────────
# URL of the Redis instance used as Celery broker and result backend.
# When running via docker-compose this should point at the redis service name.
REDIS_URL=redis://redis:6379/0

# Set to true to dispatch push notifications through the Celery worker queue
# instead of running them inline in FastAPI BackgroundTasks.
# Requires the worker service to be running (--profile worker).
ENABLE_PUSH_QUEUE=false

# Set to true to enable the Celery beat scheduler for maintenance tasks
# (quiet period expiration, device pruning, nightly backup trigger).
# Requires the beat service to be running (--profile worker).
ENABLE_CELERY_BEAT=false

# ── Backups ───────────────────────────────────────────────────────────────────
# How many days of local backups to keep (pruned by backup.sh).
BACKUP_RETENTION_DAYS=14
# Local directory where backup.sh writes timestamped backup folders.
BACKUP_DIR=/backups/bluebird

# ── Offsite backup sync ───────────────────────────────────────────────────────
# Set to true to enable rclone offsite sync (scripts/backup_offsite.sh).
OFFSITE_BACKUP_ENABLED=false
# rclone remote:path, e.g. "b2:my-bucket/bluebird" or "s3:bucket/prefix"
OFFSITE_BACKUP_TARGET=
# Path to the rclone configuration file.
RCLONE_CONFIG_PATH=/config/rclone.conf

# ── Health monitor ────────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=60
HEALTH_EMAIL_COOLDOWN_MINUTES=30
